// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

model Workspace {
  id String @id @default(cuid())

  name String

  slug String @unique

  users User[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  themes    Theme[]
  feedbacks Feedback[]
}

model User {
  id String @id @default(cuid())

  name         String
  email        String @unique
  passwordHash String

  role UserRole @default(VIEWER)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

enum FeedbackChannel {
  SUPPORT_TICKET
  APP_STORE
  PLAY_STORE
  TWITTER
  SALES_CALL
  SURVEY
  COMMUNITY
  CSV_IMPORT
  MANUAL
}

enum FeedbackStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model Theme {
  id String @id @default(cuid())

  name        String
  color       String
  description String?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  feedbacks FeedbackTheme[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model FeedbackTheme {
  feedbackId String
  themeId    String

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
  @@index([themeId])
}

model Feedback {
  id String @id @default(cuid())

  content String

  channel FeedbackChannel

  customerLabel String?

  status FeedbackStatus @default(SUBMITTED)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  themes FeedbackTheme[]

  analysis FeedbackAnalysis?

  embedding FeedbackEmbedding?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeedbackEmbedding {
  id String @id @default(cuid())

  feedbackId String   @unique
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  provider String

  model String

  embedding Unsupported("vector")

  createdAt DateTime @default(now())

  @@index([feedbackId])
}

enum FeatureArea {
  DASHBOARD
  PERFORMANCE
  AUTHENTICATION
  BILLING
  ANALYTICS
  COLLABORATION
  SEARCH
  MOBILE
  NOTIFICATIONS
  EXPORTS
  AI
  UI_UX
  OTHER
}

model FeedbackAnalysis {
  id String @id @default(cuid())

  feedbackId String   @unique
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  sentiment Sentiment

  sentimentScore Float

  summary String

  featureArea FeatureArea

  keywords String[]

  provider String

  model String

  processingTimeMs Int?

  cached Boolean @default(false)

  analyzedAt DateTime @default(now())

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([feedbackId])
}
